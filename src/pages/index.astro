---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile.js';

const formAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || 'YOUR_WEB3FORMS_ACCESS_KEY';
const currentYear = new Date().getFullYear();
---

<BaseLayout>
  <main class="site-shell">
    <nav class="nav" aria-label="Primary navigation">
      <a class="brand" href="#top" aria-label="Mridul Nohria home">
        <span class="brand-mark">MN</span>
        <span class="brand-text">Mridul<br />Nohria</span>
      </a>
      <div class="nav-links">
        <a href="#work">Work</a>
        <a href="#skills">Skills</a>
        <a href="#contact">Contact</a>
      </div>
    </nav>

    <section id="top" class="hero section-grid">
      <div class="hero-copy">
        <p class="eyebrow">Early-career software developer • UBC CS</p>
        <h1>
          Reliable software,
          <span>built with character.</span>
        </h1>
        <p class="lede">{profile.summary}</p>

        <div class="hero-actions" aria-label="Contact and profile links">
          <a class="button primary" href="#contact">Work with me</a>
          <a class="button secondary" href={profile.resume} target="_blank" rel="noreferrer">Resume</a>
          <a class="button ghost" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
        </div>

        <div class="fact-strip" aria-label="Quick facts">
          {profile.quickFacts.map((fact) => <span>{fact}</span>)}
        </div>
      </div>

      <aside class="hero-card" aria-label="Profile card for Mridul Nohria">
        <div class="orbit orbit-one"></div>
        <div class="orbit orbit-two"></div>
        <img src={profile.image} alt="Mridul Nohria" />
        <div class="profile-caption">
          <span>Available for</span>
          <strong>Software internships & junior dev roles</strong>
        </div>
      </aside>
    </section>

    <section class="marquee" aria-label="Technical focus areas">
      <div class="marquee-track">
        <span>Python</span><span>Java</span><span>C++</span><span>REST APIs</span><span>SQL</span><span>Docker</span><span>CI/CD</span><span>Testing</span>
        <span>Python</span><span>Java</span><span>C++</span><span>REST APIs</span><span>SQL</span><span>Docker</span><span>CI/CD</span><span>Testing</span>
      </div>
    </section>

    <section class="about section-grid" id="about">
      <div>
        <p class="eyebrow">About</p>
        <h2>Systems-minded, user-aware, and quality-focused.</h2>
      </div>
      <div class="about-card">
        <p>
          I’m {profile.name}, a Computer Science student at the University of British Columbia.
          My strongest work sits where practical software engineering meets reliability: testing,
          debugging, APIs, databases, and clean user-facing workflows.
        </p>
        <p>
          I like projects that prove they work — not just demos that look good once. That is why my
          portfolio highlights test automation, CI/CD, Linux tooling, full-stack development, and
          maintainable architecture.
        </p>
      </div>
    </section>

    <section id="work" class="work">
      <div class="section-header">
        <p class="eyebrow">Selected work</p>
        <h2>Projects with proof points.</h2>
      </div>

      <div class="project-grid">
        {profile.projects.map((project, index) => (
          <article class="project-card" style={`--card-index: '${String(index + 1).padStart(2, '0')}'`}>
            <div class="project-number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</div>
            <div class="project-topline">
              <span>{project.label}</span>
              <strong>{project.impact}</strong>
            </div>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <div class="tag-list">
              {project.stack.map((item) => <span>{item}</span>)}
            </div>
            <a class="project-link" href={project.href} target="_blank" rel="noreferrer">
              View project <span aria-hidden="true">↗</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section id="skills" class="skills section-grid">
      <div>
        <p class="eyebrow">Stack</p>
        <h2>Tools I use to ship cleaner software.</h2>
      </div>
      <div class="skills-grid">
        {profile.skillGroups.map((group) => (
          <article class="skill-card">
            <h3>{group.name}</h3>
            <div class="tag-list compact">
              {group.skills.map((skill) => <span>{skill}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="wins">
      <div class="section-header">
        <p class="eyebrow">Signals</p>
        <h2>Awards, certifications, and momentum.</h2>
      </div>
      <div class="wins-grid">
        {profile.achievements.map((achievement) => (
          <div class="win-item">
            <span>★</span>
            <p>{achievement}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="contact" class="contact section-grid">
      <div>
        <p class="eyebrow">Contact</p>
        <h2>Have a role, project, or opportunity?</h2>
        <p class="contact-note">
          Send a message through the form, or reach me directly at
          <a href={`mailto:${profile.email}`}>{profile.email}</a>.
        </p>
        <div class="social-row">
          <a href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
          <a href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
          <a href={profile.resume} target="_blank" rel="noreferrer">Resume</a>
        </div>
      </div>

      <form class="contact-form" id="contact-form" aria-label="Contact form">
        <input type="hidden" name="access_key" value={formAccessKey} />
        <input type="hidden" name="subject" value="New portfolio message for Mridul Nohria" />
        <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

        <label>
          Name
          <input name="name" type="text" placeholder="Your name" required />
        </label>
        <label>
          Email
          <input name="email" type="email" placeholder="you@example.com" required />
        </label>
        <label>
          Message
          <textarea name="message" rows="5" placeholder="Tell me what you’re building or hiring for..." required></textarea>
        </label>
        <button class="button primary form-button" type="submit">Send message</button>
        <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>
  </main>

  <footer class="footer">
    <p>© {currentYear} {profile.name}. Built with Astro and deployed on GitHub Pages.</p>
    <a href="#top">Back to top ↑</a>
  </footer>

  <script>
    const form = document.querySelector('#contact-form');
    const status = document.querySelector('#form-status');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const key = String(formData.get('access_key') || '');

      if (!key || key === 'YOUR_WEB3FORMS_ACCESS_KEY') {
        status.textContent = 'Form needs a Web3Forms access key. Use the email link for now.';
        status.dataset.state = 'warning';
        return;
      }

      status.textContent = 'Sending...';
      status.dataset.state = 'loading';

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        });
        const result = await response.json();

        if (result.success) {
          status.textContent = 'Message sent. Thanks for reaching out!';
          status.dataset.state = 'success';
          form.reset();
        } else {
          status.textContent = result.message || 'Something went wrong. Please email me directly.';
          status.dataset.state = 'error';
        }
      } catch (error) {
        status.textContent = 'Network error. Please email me directly.';
        status.dataset.state = 'error';
      }
    });
  </script>
</BaseLayout>

<style is:global>
  :root {
    --bg: #0d1117;
    --panel: #151b23;
    --panel-strong: #f6f0df;
    --ink: #f6f0df;
    --muted: #aeb6c2;
    --line: rgba(246, 240, 223, 0.16);
    --lime: #b7ff3c;
    --blue: #6dd3ff;
    --pink: #ff4ecd;
    --orange: #ff9f1c;
    --shadow: 0 30px 100px rgba(0, 0, 0, 0.35);
    --radius-xl: 36px;
    --radius-lg: 26px;
    --radius-md: 18px;
    --max: 1180px;
    font-family: 'Mona Sans', 'Hubot Sans', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; background: var(--bg); }
  body {
    margin: 0;
    color: var(--ink);
    background:
      radial-gradient(circle at top left, rgba(183, 255, 60, 0.20), transparent 34rem),
      radial-gradient(circle at 90% 12%, rgba(109, 211, 255, 0.16), transparent 30rem),
      radial-gradient(circle at 75% 75%, rgba(255, 78, 205, 0.10), transparent 28rem),
      var(--bg);
    min-height: 100vh;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.25;
    background-image:
      linear-gradient(rgba(246, 240, 223, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(246, 240, 223, 0.06) 1px, transparent 1px);
    background-size: 54px 54px;
    mask-image: linear-gradient(to bottom, black, transparent 82%);
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }

  .site-shell {
    width: min(calc(100% - 32px), var(--max));
    margin: 0 auto;
  }

  .nav {
    position: sticky;
    top: 16px;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px;
    margin: 16px 0 64px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(13, 17, 23, 0.74);
    backdrop-filter: blur(20px);
    box-shadow: var(--shadow);
  }

  .brand { display: inline-flex; align-items: center; gap: 12px; }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--lime);
    color: #0d1117;
    font-weight: 950;
    letter-spacing: -0.08em;
  }
  .brand-text {
    font-size: 0.83rem;
    line-height: 0.9;
    text-transform: uppercase;
    font-weight: 900;
    letter-spacing: 0.03em;
  }
  .nav-links { display: flex; gap: 6px; }
  .nav-links a {
    padding: 12px 16px;
    color: var(--muted);
    border-radius: 999px;
    transition: color 180ms ease, background 180ms ease;
  }
  .nav-links a:hover { color: var(--ink); background: rgba(246, 240, 223, 0.08); }

  .section-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: 32px;
    align-items: center;
    margin: 96px 0;
  }

  .hero { margin-top: 0; min-height: 650px; }
  .eyebrow {
    margin: 0 0 18px;
    color: var(--lime);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  h1, h2, h3, p { margin-top: 0; }
  h1 {
    max-width: 820px;
    margin-bottom: 22px;
    font-size: clamp(4.5rem, 12vw, 9.6rem);
    line-height: 0.78;
    letter-spacing: -0.11em;
    font-weight: 1000;
  }
  h1 span {
    display: block;
    font-weight: 650;
    letter-spacing: -0.085em;
    color: transparent;
    -webkit-text-stroke: 1.4px var(--ink);
  }
  h2 {
    font-size: clamp(2.3rem, 5vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.075em;
    margin-bottom: 0;
  }
  h3 {
    font-size: clamp(1.6rem, 3vw, 2.35rem);
    letter-spacing: -0.05em;
    line-height: 0.98;
  }
  .lede {
    max-width: 700px;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.65;
  }

  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin: 34px 0; }
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 20px;
    border-radius: 999px;
    border: 1px solid var(--line);
    font-weight: 900;
    transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    cursor: pointer;
  }
  .button:hover { transform: translateY(-2px); box-shadow: 0 18px 42px rgba(0, 0, 0, 0.28); }
  .button.primary { background: var(--lime); color: #0d1117; border-color: var(--lime); }
  .button.secondary { background: var(--panel-strong); color: #0d1117; border-color: var(--panel-strong); }
  .button.ghost { color: var(--ink); background: rgba(246, 240, 223, 0.06); }

  .fact-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .fact-strip span, .tag-list span {
    display: inline-flex;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 9px 12px;
    color: var(--muted);
    background: rgba(246, 240, 223, 0.04);
    font-size: 0.9rem;
  }

  .hero-card {
    position: relative;
    isolation: isolate;
    min-height: 570px;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(135deg, rgba(246, 240, 223, 0.10), rgba(246, 240, 223, 0.02)),
      var(--panel);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .hero-card::before {
    content: '</>';
    position: absolute;
    top: 20px;
    right: 24px;
    font-size: 5.6rem;
    font-weight: 1000;
    letter-spacing: -0.12em;
    color: rgba(246, 240, 223, 0.08);
  }
  .hero-card::after {
    content: 'BUILD • TEST • SHIP';
    position: absolute;
    left: 24px;
    top: 28px;
    color: #0d1117;
    background: var(--orange);
    border-radius: 999px;
    padding: 10px 14px;
    font-size: 0.76rem;
    font-weight: 1000;
    letter-spacing: 0.12em;
    z-index: 3;
  }
  .hero-card img {
    position: absolute;
    left: 50%;
    bottom: 84px;
    width: min(70%, 390px);
    transform: translateX(-50%) scale(1.4);
    transform-origin: bottom center;
    filter: drop-shadow(0 30px 35px rgba(0, 0, 0, 0.46));
    z-index: 2;
  }
  .orbit {
    position: absolute;
    border: 1px solid rgba(246, 240, 223, 0.18);
    border-radius: 50%;
    z-index: 1;
  }
  .orbit-one { width: 440px; height: 440px; left: -90px; bottom: 30px; }
  .orbit-two { width: 520px; height: 520px; right: -190px; bottom: 0; border-color: rgba(183, 255, 60, 0.35); }
  .profile-caption {
    position: absolute;
    left: 20px;
    right: 20px;
    bottom: 20px;
    padding: 20px;
    border-radius: 24px;
    background: var(--panel-strong);
    color: #0d1117;
    z-index: 4;
  }
  .profile-caption span { display: block; text-transform: uppercase; font-size: 0.76rem; font-weight: 1000; letter-spacing: 0.13em; opacity: 0.7; }
  .profile-caption strong { display: block; margin-top: 6px; font-size: 1.35rem; letter-spacing: -0.05em; line-height: 0.95; }

  .marquee {
    overflow: hidden;
    border-block: 1px solid var(--line);
    margin: 84px 0;
  }
  .marquee-track {
    display: flex;
    gap: 22px;
    width: max-content;
    padding: 20px 0;
    animation: move 24s linear infinite;
  }
  .marquee span {
    font-size: clamp(2rem, 7vw, 5.8rem);
    line-height: 0.8;
    font-weight: 1000;
    letter-spacing: -0.1em;
    text-transform: uppercase;
    color: transparent;
    -webkit-text-stroke: 1px rgba(246, 240, 223, 0.55);
  }
  @keyframes move { to { transform: translateX(-50%); } }

  .about-card {
    padding: 34px;
    border-radius: var(--radius-lg);
    background: rgba(246, 240, 223, 0.07);
    border: 1px solid var(--line);
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.75;
  }
  .about-card p:last-child { margin-bottom: 0; }

  .work, .wins { margin: 108px 0; }
  .section-header { margin-bottom: 28px; }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .project-card {
    position: relative;
    min-height: 430px;
    padding: 30px;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: rgba(21, 27, 35, 0.82);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .project-card::after {
    content: var(--card-index);
    position: absolute;
    right: -12px;
    bottom: -18px;
    font-size: 12rem;
    font-weight: 1000;
    letter-spacing: -0.15em;
    color: rgba(246, 240, 223, 0.035);
    pointer-events: none;
  }
  .project-card:nth-child(1) { background: linear-gradient(135deg, rgba(183, 255, 60, 0.16), rgba(21, 27, 35, 0.86)); }
  .project-card:nth-child(2) { background: linear-gradient(135deg, rgba(109, 211, 255, 0.15), rgba(21, 27, 35, 0.86)); }
  .project-card:nth-child(3) { background: linear-gradient(135deg, rgba(255, 78, 205, 0.13), rgba(21, 27, 35, 0.86)); }
  .project-card:nth-child(4) { background: linear-gradient(135deg, rgba(255, 159, 28, 0.13), rgba(21, 27, 35, 0.86)); }
  .project-number {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--panel-strong);
    color: #0d1117;
    font-weight: 1000;
    margin-bottom: 32px;
  }
  .project-topline {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    color: var(--muted);
    font-size: 0.88rem;
    margin-bottom: 12px;
  }
  .project-topline strong { color: var(--lime); }
  .project-card p { color: var(--muted); line-height: 1.62; }
  .tag-list { display: flex; flex-wrap: wrap; gap: 8px; margin-top: auto; }
  .tag-list.compact { margin-top: 16px; }
  .project-link {
    align-self: flex-start;
    margin-top: 24px;
    color: var(--ink);
    font-weight: 950;
    border-bottom: 2px solid var(--lime);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }
  .skill-card {
    padding: 24px;
    border-radius: var(--radius-lg);
    background: var(--panel-strong);
    color: #0d1117;
  }
  .skill-card h3 { margin-bottom: 14px; }
  .skill-card .tag-list span {
    border-color: rgba(13, 17, 23, 0.14);
    background: rgba(13, 17, 23, 0.06);
    color: #0d1117;
  }

  .wins-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  .win-item {
    min-height: 150px;
    padding: 22px;
    border-radius: var(--radius-lg);
    background: rgba(246, 240, 223, 0.06);
    border: 1px solid var(--line);
  }
  .win-item span { color: var(--lime); font-size: 1.4rem; }
  .win-item p { margin: 14px 0 0; color: var(--muted); line-height: 1.45; }

  .contact { align-items: start; }
  .contact-note {
    color: var(--muted);
    line-height: 1.65;
    max-width: 520px;
    margin-top: 20px;
  }
  .contact-note a { color: var(--lime); font-weight: 900; }
  .social-row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 24px; }
  .social-row a {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 10px 14px;
    color: var(--muted);
  }
  .contact-form {
    padding: 26px;
    border-radius: var(--radius-xl);
    background: var(--panel-strong);
    color: #0d1117;
    box-shadow: var(--shadow);
  }
  .contact-form label {
    display: grid;
    gap: 8px;
    font-weight: 950;
    margin-bottom: 16px;
  }
  input, textarea {
    width: 100%;
    border: 1px solid rgba(13, 17, 23, 0.14);
    border-radius: 18px;
    padding: 14px 16px;
    background: #fffaf0;
    color: #0d1117;
    font: inherit;
    outline: none;
  }
  input:focus, textarea:focus { border-color: #0d1117; box-shadow: 0 0 0 4px rgba(13, 17, 23, 0.08); }
  .form-button { width: 100%; border-color: #0d1117; }
  .form-status { min-height: 24px; margin: 14px 0 0; font-weight: 800; }
  .form-status[data-state='success'] { color: #0a7b33; }
  .form-status[data-state='error'], .form-status[data-state='warning'] { color: #9a2500; }
  .hidden { display: none; }

  .footer {
    width: min(calc(100% - 32px), var(--max));
    margin: 0 auto 28px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    gap: 16px;
    color: var(--muted);
  }
  .footer a { color: var(--ink); font-weight: 900; }

  @media (max-width: 920px) {
    .section-grid { grid-template-columns: 1fr; margin: 78px 0; }
    .hero { min-height: auto; }
    .hero-card { min-height: 520px; }
    .project-grid, .wins-grid { grid-template-columns: 1fr; }
    .skills-grid { grid-template-columns: 1fr; }
    .nav { margin-bottom: 48px; }
  }

  @media (max-width: 640px) {
    .site-shell { width: min(calc(100% - 22px), var(--max)); }
    .nav { border-radius: 28px; align-items: flex-start; }
    .nav-links a { padding: 10px 9px; font-size: 0.9rem; }
    .brand-text { display: none; }
    h1 { font-size: clamp(3.7rem, 18vw, 5.4rem); }
    h1 span { -webkit-text-stroke-width: 1px; }
    .hero-card { min-height: 460px; }
    .hero-card img { width: 78%; transform: translateX(-50%) scale(1.25); bottom: 86px; }
    .project-card { min-height: 390px; padding: 24px; }
    .footer { flex-direction: column; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation-duration: 0.001ms !important; animation-iteration-count: 1 !important; scroll-behavior: auto !important; }
  }
</style>
